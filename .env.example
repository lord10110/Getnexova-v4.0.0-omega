# ═══════════════════════════════════════════════════════
# GetNexova v4.0.0 OMEGA — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════

# ─── LLM API Keys ────────────────────────────────────
# Free tier (at least one recommended)
GROQ_API_KEY=
GEMINI_API_KEY=

# Paid tier (optional, used as fallback)
ANTHROPIC_API_KEY=

# Local LLM (optional)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Budget Controls ─────────────────────────────────
MAX_COST_PER_RUN=5.0
MAX_COST_PER_MONTH=50.0

# ─── Notifications (all optional) ────────────────────
DISCORD_WEBHOOK=
SLACK_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Advanced Tools Container ────────────────────────
ADVANCED_TOOLS_URL=http://advanced-tools:5050
ADVANCED_TOOLS_ENABLED=false

# ─── Scan Defaults ───────────────────────────────────
NEXOVA_MODE=standard
